{
	"name": "soshosai-abuse",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy --minify",
		"deploy:verified": "wrangler deploy --minify --var SOURCE_COMMIT:$(git rev-parse HEAD) --var BUILD_AT:$(date -u +%Y-%m-%dT%H:%M:%SZ)",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings"
	},
	"dependencies": {
		"@hono/standard-validator": "^0.2.2",
		"hono": "^4.12.15",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"wrangler": "^4.85.0"
	}
}